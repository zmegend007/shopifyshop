                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_z39Edp"
              ]
            },
            "accordion_row_wNCkaX": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Are all materials natural?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_XczKAX": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Simple answer: Yes. Marie-Louise works only with natural fibers. We acknowledge, however, that sustainability is not always binary and that the impact of a material depends on context and sourcing.<\/p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
