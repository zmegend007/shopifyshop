            "text_PqQ9BH": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<h2>HESSENCE ERITAGE <br\/>BACHELOR COLLECTION<br\/>#SS24\/25 <\/h2>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h3",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
