                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_z39Edp": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Creative collaboration is always welcomed. If you are a stylist, curator, or creative interested in working with this look, feel free to connect via the contact page or Instagram.<\/p>",
                    "width": "100%",
