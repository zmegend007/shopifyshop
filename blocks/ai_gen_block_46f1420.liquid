{% doc %}
  @prompt
    Create a dynamic "about me" block with a 3:4 ratio image slot on the right side and text on the left side. Make it premium. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-me-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-about-me-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-about-me-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 0.75fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
    min-height: 500px;
  }

  .ai-about-me-text-{{ ai_gen_id }} {
    padding-right: {{ block.settings.text_padding }}px;
  }

  .ai-about-me-heading-{{ ai_gen_id }} {
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    font-weight: {{ settings.type_heading_font.weight }};
    font-style: {{ settings.type_heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    letter-spacing: -0.02em;
  }

  .ai-about-me-description-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-style: {{ settings.type_body_font.style }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_margin }}px;
  }

  .ai-about-me-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: 500;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    box-shadow: {{ block.settings.button_shadow_x }}px {{ block.settings.button_shadow_y }}px {{ block.settings.button_shadow_blur }}px {{ block.settings.button_shadow_color }};
  }

  .ai-about-me-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
    box-shadow: {{ block.settings.button_shadow_x }}px {{ block.settings.button_shadow_y | plus: 2 }}px {{ block.settings.button_shadow_blur | plus: 4 }}px {{ block.settings.button_shadow_color }};
  }

  .ai-about-me-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: {{ block.settings.image_shadow_x }}px {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_color }};
  }

  .ai-about-me-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-about-me-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-about-me-image-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
    color: #999;
  }

  .ai-about-me-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    color: #666;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  {% if block.settings.enable_hover_effect %}
    .ai-about-me-image-container-{{ ai_gen_id }}:hover .ai-about-me-image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  @media screen and (max-width: 768px) {
    .ai-about-me-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
      text-align: center;
    }

    .ai-about-me-text-{{ ai_gen_id }} {
      padding-right: 0;
      order: {{ block.settings.mobile_text_order }};
    }

    .ai-about-me-image-container-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_image_order }};
      max-width: 400px;
      margin: 0 auto;
    }

    .ai-about-me-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-about-me-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-about-me-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-about-me-button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.9 }}px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-about-me-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-me-container-{{ ai_gen_id }}">
    <div class="ai-about-me-content-{{ ai_gen_id }}">
      <div class="ai-about-me-text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-about-me-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-about-me-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-about-me-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
            {% if block.settings.show_button_arrow %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7,7 17,7 17,17"></polyline>
              </svg>
            {% endif %}
          </a>
        {% endif %}
      </div>

      <div class="ai-about-me-image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-about-me-image-{{ ai_gen_id }}"
            loading="lazy"
            width="600"
            height="800"
          >
        {% else %}
          <div class="ai-about-me-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-about-me-empty-state-{{ ai_gen_id }}">
              Add your photo
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About me",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About me"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Share your story, passion, and expertise. Connect with your audience through authentic storytelling that builds trust and showcases what makes you unique.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_button_arrow",
      "label": "Show arrow icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Content gap",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_padding",
