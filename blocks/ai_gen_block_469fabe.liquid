{% doc %}
  @prompt
    A magazine-style editorial grid where I can customize which collection thumbnails I want to add from existing thumbnails. Collection names should appear on the image when hoovering over. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-grid-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-editorial-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  {% if block.settings.featured_layout == 'large_first' %}
    .ai-editorial-grid__item-{{ ai_gen_id }}:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }
  {% endif %}

  .ai-editorial-grid__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-editorial-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }}:hover .ai-editorial-grid__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom_scale }});
  }

  .ai-editorial-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      {{ block.settings.overlay_direction }},
      {{ block.settings.overlay_color_start }},
      {{ block.settings.overlay_color_end }}
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }}:hover .ai-editorial-grid__overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-editorial-grid__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    text-align: center;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    transform: translateY(10px);
    transition: transform 0.3s ease;
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    font-style: {{ settings.type_heading_font.style }};
    font-weight: {{ settings.type_heading_font.weight }};
  }

  .ai-editorial-grid__item-{{ ai_gen_id }}:hover .ai-editorial-grid__title-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .ai-editorial-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-editorial-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-editorial-grid__item-{{ ai_gen_id }}:nth-child(1) {
      grid-column: span 1;
      grid-row: span 1;
    }

    .ai-editorial-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-editorial-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 0;
    }
  }
{% endstyle %}

<div class="ai-editorial-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      {% if collection != blank %}
        <div class="ai-editorial-grid__item-{{ ai_gen_id }}">
          <a href="{{ collection.url }}" class="ai-editorial-grid__link-{{ ai_gen_id }}">
            <div class="ai-editorial-grid__image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                  class="ai-editorial-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ collection.featured_image.width }}"
                  height="{{ collection.featured_image.height }}"
                >
              {% else %}
                <div class="ai-editorial-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              
              <div class="ai-editorial-grid__overlay-{{ ai_gen_id }}">
                <h3 class="ai-editorial-grid__title-{{ ai_gen_id }}">
                  {{ collection.title }}
                </h3>
              </div>
            </div>
          </a>
        </div>
      {% elsif forloop.first %}
        <div class="ai-editorial-grid__item-{{ ai_gen_id }}">
          <div class="ai-editorial-grid__placeholder-{{ ai_gen_id }}">
            {{ 'collection-apparel-1' | placeholder_svg_tag }}
            <div class="ai-editorial-grid__empty-state-{{ ai_gen_id }}">
              Add collections to create your editorial grid
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Editorial collection grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "featured_layout",
      "label": "Make first collection larger",
      "default": true
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "16/9", "label": "Wide (16:9)" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "hover_lift",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Hover lift effect",
      "default": 4
    },
    {
      "type": "range",
      "id": "image_zoom_scale",
      "min": 1.0,
      "max": 1.2,
      "step": 0.1,
      "label": "Image zoom on hover",
      "default": 1.1
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 70
    },
    {
      "type": "select",
      "id": "overlay_direction",
      "label": "Overlay gradient direction",
      "options": [
        { "value": "to bottom", "label": "Top to bottom" },
        { "value": "to top", "label": "Bottom to top" },
        { "value": "to right", "label": "Left to right" },
        { "value": "to left", "label": "Right to left" }
      ],
      "default": "to bottom"
    },
    {
      "type": "color",
      "id": "overlay_color_start",
      "label": "Overlay start color",
      "default": "rgba(0,0,0,0.3)"
    },
    {
      "type": "color",
      "id": "overlay_color_end",
      "label": "Overlay end color",
      "default": "rgba(0,0,0,0.7)"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Collection 3"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Collection 4"
    },
    {
      "type": "collection",
      "id": "collection_5",
      "label": "Collection 5"
    },
    {
      "type": "collection",
      "id": "collection_6",
      "label": "Collection 6"
    }
  ],
  "presets": [
    {
      "name": "Editorial collection grid"
    }
  ]
}
{% endschema %}