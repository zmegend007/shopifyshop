{% doc %}
  @prompt
    Make a grid for magazine logos suitable for showing where publications have been. Make 10 slots and create a button where I can add further slots when needed. Make the grid centered based on the logos uploaded automatically so if only 4 logos are in they are centered and if more is added its getting adjusted. , Great, make it suitable for mobile devices showing maximum 3 in a row. For Desktop maximum 6. Always centered. Hide unfilled slots. The button for adding more slots should only be visible for me not visitors., Great. Remove the "add more slots" box and center all logos in the grid. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-magazine-grid-heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.heading_margin }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-magazine-grid-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-grid-logos-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
    max-width: {{ block.settings.grid_max_width }}px;
    justify-items: center;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-logo-slot-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.slot_background_color }};
    border: {{ block.settings.slot_border_width }}px solid {{ block.settings.slot_border_color }};
    border-radius: {{ block.settings.slot_border_radius }}px;
    padding: {{ block.settings.slot_padding }}px;
    transition: all 0.3s ease;
  }

  .ai-magazine-logo-slot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.slot_hover_background_color }};
    border-color: {{ block.settings.slot_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-magazine-logo-slot-{{ ai_gen_id }}.empty {
    display: none;
  }

  .ai-magazine-logo-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: {{ block.settings.logo_filter }};
    transition: filter 0.3s ease;
  }

  .ai-magazine-logo-slot-{{ ai_gen_id }}:hover .ai-magazine-logo-image-{{ ai_gen_id }} {
    filter: {{ block.settings.logo_hover_filter }};
  }

  @media screen and (max-width: 768px) {
    .ai-magazine-grid-logos-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }

    .ai-magazine-logo-slot-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
      padding: {{ block.settings.slot_padding | times: 0.8 }}px;
    }

    .ai-magazine-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-magazine-grid-logos-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.6 }}px;
    }

    .ai-magazine-logo-slot-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
      padding: {{ block.settings.slot_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<magazine-logos-grid-{{ ai_gen_id }}
  class="ai-magazine-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-magazine-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-magazine-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-magazine-grid-wrapper-{{ ai_gen_id }}">
      <div class="ai-magazine-grid-logos-{{ ai_gen_id }}" id="ai-magazine-grid-logos-{{ ai_gen_id }}">
        {% for i in (1..50) %}
          {% liquid
            assign logo_key = 'logo_' | append: i
            assign logo_alt_key = 'logo_' | append: i | append: '_alt'
            assign logo_url_key = 'logo_' | append: i | append: '_url'
            
            assign logo = block.settings[logo_key]
            assign logo_alt = block.settings[logo_alt_key]
            assign logo_url = block.settings[logo_url_key]
          %}

          {% if logo %}
            <div class="ai-magazine-logo-slot-{{ ai_gen_id }}" data-slot="{{ i }}">
              {% if logo_url != blank %}
                <a href="{{ logo_url }}" target="_blank" rel="noopener noreferrer">
                  <img
                    src="{{ logo | image_url: width: 400 }}"
                    alt="{{ logo_alt | default: logo.alt | escape }}"
                    class="ai-magazine-logo-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ logo.width }}"
                    height="{{ logo.height }}"
                  >
                </a>
              {% else %}
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo_alt | default: logo.alt | escape }}"
                  class="ai-magazine-logo-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ logo.width }}"
                  height="{{ logo.height }}"
                >
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</magazine-logos-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineLogosGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.gridContainer = this.querySelector('#ai-magazine-grid-logos-{{ ai_gen_id }}');
        this.updateGridLayout();
        
        window.addEventListener('resize', () => this.updateGridLayout());
      }

      updateGridLayout() {
        const filledSlots = this.gridContainer.querySelectorAll('.ai-magazine-logo-slot-{{ ai_gen_id }}');
        const filledCount = filledSlots.length;
        
        if (filledCount > 0) {
          const isMobile = window.innerWidth <= 768;
          const maxColumns = isMobile ? 3 : 6;
          
          const rows = Math.ceil(filledCount / maxColumns);
          const lastRowItems = filledCount % maxColumns;
          
          filledSlots.forEach(slot => {
            slot.style.gridColumn = 'auto';
          });
          
          if (lastRowItems > 0 && rows > 1) {
            const startIndex = (rows - 1) * maxColumns;
            const lastRowSlots = Array.from(filledSlots).slice(startIndex);
            
            lastRowSlots.forEach((slot, index) => {
              if (isMobile) {
                if (lastRowItems === 1) {
                  slot.style.gridColumn = '2 / 3';
                } else if (lastRowItems === 2) {
                  slot.style.gridColumn = index === 0 ? '1 / 2' : '3 / 4';
                } else {
                  slot.style.gridColumn = 'auto';
                }
              } else {
                const offset = Math.floor((maxColumns - lastRowItems) / 2) + 1;
                slot.style.gridColumn = `${offset + index} / ${offset + index + 1}`;
              }
            });
          }
        }
      }
    }

    customElements.define('magazine-logos-grid-{{ ai_gen_id }}', MagazineLogosGrid{{ ai_gen_id }});
  })();
</script>

