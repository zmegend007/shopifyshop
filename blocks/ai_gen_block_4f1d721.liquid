{% doc %}
  @prompt
    A dynamic "recommended product" feature where I can link each product individually with my selection from another collection. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recommended-products-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-recommended-products__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-recommended-products__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-recommended-products__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.title_margin }}px;
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    font-weight: {{ settings.type_heading_font.weight }};
  }

  .ai-recommended-products__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-recommended-products__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_margin }}px;
  }

  .ai-recommended-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    position: relative;
  }

  .ai-recommended-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow }}px {{ block.settings.hover_shadow | times: 2 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-recommended-product-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-recommended-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-recommended-product-card-{{ ai_gen_id }}:hover .ai-recommended-product-image-{{ ai_gen_id }} img {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-recommended-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-recommended-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-recommended-product-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-recommended-product-title-{{ ai_gen_id }} {
    color: {{ block.settings.product_title_color }};
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.3;
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
  }

  .ai-recommended-product-price-{{ ai_gen_id }} {
    color: {{ block.settings.product_price_color }};
    font-size: {{ block.settings.product_price_size }}px;
    font-weight: 500;
    margin-bottom: 12px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-recommended-product-description-{{ ai_gen_id }} {
    color: {{ block.settings.product_description_color }};
    font-size: {{ block.settings.product_description_size }}px;
    line-height: 1.5;
    margin-bottom: 16px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-recommended-product-link-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-recommended-product-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-1px);
  }

  .ai-recommended-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-style: italic;
  }

  @media screen and (max-width: 768px) {
    .ai-recommended-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-recommended-products__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-recommended-product-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-recommended-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-recommended-products__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-recommended-products__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-recommended-products__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-recommended-products__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign has_products = false
      for i in (1..6)
        assign product_key = 'product_' | append: i
        assign product = block.settings[product_key]
        if product != blank
          assign has_products = true
          break
        endif
      endfor
    %}

    {% if has_products %}
      <div class="ai-recommended-products__grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign custom_link_key = 'custom_link_' | append: i
            assign custom_title_key = 'custom_title_' | append: i
            assign custom_description_key = 'custom_description_' | append: i
            
            assign product = block.settings[product_key]
            assign custom_link = block.settings[custom_link_key]
            assign custom_title = block.settings[custom_title_key]
            assign custom_description = block.settings[custom_description_key]
          %}

          {% if product != blank %}
            <div class="ai-recommended-product-card-{{ ai_gen_id }}">
              <div class="ai-recommended-product-image-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: block.settings.image_aspect_ratio }}"
                  >
                {% else %}
                  <div class="ai-recommended-product-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-recommended-product-content-{{ ai_gen_id }}">
                <h3 class="ai-recommended-product-title-{{ ai_gen_id }}">
                  {% if custom_title != blank %}
                    {{ custom_title }}
                  {% else %}
                    {{ product.title }}
                  {% endif %}
                </h3>

                {% if block.settings.show_price %}
                  <div class="ai-recommended-product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <s style="opacity: 0.6; margin-left: 8px;">{{ product.compare_at_price | money }}</s>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_description %}
                  <div class="ai-recommended-product-description-{{ ai_gen_id }}">
                    {% if custom_description != blank %}
                      {{ custom_description }}
                    {% else %}
                      {{ product.description | strip_html | truncate: 120 }}
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_button %}
                  <a
                    href="{% if custom_link != blank %}{{ custom_link }}{% else %}{{ product.url }}{% endif %}"
                    class="ai-recommended-product-link-{{ ai_gen_id }}"
                  >
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-recommended-empty-state-{{ ai_gen_id }}">
        <p>Select products to display your recommendations</p>
      </div>
    {% endif %}
  </div>
</div>

