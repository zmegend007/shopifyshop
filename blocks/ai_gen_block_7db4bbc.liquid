{% doc %}
  @prompt
    I want a clean and simple block with a button centered inside of it where I can write "Custom Piece Request" that will take the visitor into a funnel where preset questions are asked and once they are filled in the visitor can click a button to book a time slot with us using the BookX app that is installed. Once the request is sent the page refreshes and visitor is sent back to the home page. , Great. I want a smaller text field inside the same box where I can write "How does it work?" and the visitor should be sent to the same page as if you click "Custom Piece Request" 
    
    When the visitor reach the first page where its currently a field for customer information I want: 
    
    2 options easy to toggle between and the first is "How It Works" and the other is "Book Consultation" make the colors inverted so that the normal funnel is white with black buttons but if the visitor toggles to "How It Works" its black with white buttons and room for text where I will explain and make it easy for the customer. , Great. Remove the initial "how does it work?" button in the white box but keep the other additions. , Make the font the same as the rest of the website. Make it coherent. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-request-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
  }

  .ai-custom-request-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 200px;
  }

  .ai-custom-request-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-custom-request-modal-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 20px;
  }

  .ai-custom-request-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.modal_background_color }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    padding: 40px;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    transition: all 0.3s ease;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-size: {{ settings.type_size_paragraph }}px;
    line-height: {{ settings.type_line_height_paragraph }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode {
    background-color: {{ block.settings.how_it_works_modal_background }};
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: {{ block.settings.modal_text_color }};
    padding: 5px;
    transition: color 0.3s ease;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-modal-close-{{ ai_gen_id }} {
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-mode-toggle-{{ ai_gen_id }} {
    display: flex;
    background-color: {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: 4px;
    margin-bottom: 30px;
    gap: 4px;
  }

  .ai-custom-request-toggle-option-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 16px;
    border: none;
    border-radius: {{ block.settings.button_border_radius | minus: 4 }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    transition: all 0.3s ease;
    background-color: transparent;
    color: {{ block.settings.modal_text_color }};
  }

  .ai-custom-request-toggle-option-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-toggle-option-{{ ai_gen_id }} {
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-toggle-option-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.how_it_works_modal_text }};
    color: {{ block.settings.how_it_works_modal_background }};
  }

  .ai-custom-request-step-{{ ai_gen_id }} {
    display: none;
  }

  .ai-custom-request-step-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-custom-request-step-title-{{ ai_gen_id }} {
    font-size: {{ settings.type_size_h3 }}px;
    font-weight: {{ settings.type_heading_font.weight }};
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    line-height: {{ settings.type_line_height_h3 }};
    letter-spacing: {{ settings.type_letter_spacing_h3 }};
    text-transform: {{ settings.type_case_h3 }};
    margin-bottom: 20px;
    color: {{ block.settings.modal_text_color }};
    transition: color 0.3s ease;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-step-title-{{ ai_gen_id }} {
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} {
    text-align: left;
    line-height: 1.6;
    color: {{ block.settings.how_it_works_modal_text }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ settings.type_size_paragraph }}px;
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} h3 {
    color: {{ block.settings.how_it_works_modal_text }};
    margin-top: 24px;
    margin-bottom: 12px;
    font-size: {{ settings.type_size_h5 }}px;
    font-weight: {{ settings.type_subheading_font.weight }};
    font-family: {{ settings.type_subheading_font.family }}, {{ settings.type_subheading_font.fallback_families }};
    line-height: {{ settings.type_line_height_h5 }};
    letter-spacing: {{ settings.type_letter_spacing_h5 }};
    text-transform: {{ settings.type_case_h5 }};
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} h3:first-child {
    margin-top: 0;
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} p {
    margin-bottom: 16px;
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} ul {
    margin-bottom: 16px;
    padding-left: 20px;
  }

  .ai-custom-request-how-it-works-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-custom-request-form-group-{{ ai_gen_id }} {
    margin-bottom: 20px;
    text-align: left;
  }

  .ai-custom-request-label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    font-weight: {{ settings.type_subheading_font.weight }};
    font-family: {{ settings.type_subheading_font.family }}, {{ settings.type_subheading_font.fallback_families }};
    color: {{ block.settings.modal_text_color }};
    transition: color 0.3s ease;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-label-{{ ai_gen_id }} {
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-input-{{ ai_gen_id }},
  .ai-custom-request-textarea-{{ ai_gen_id }},
  .ai-custom-request-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ settings.type_size_paragraph }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    transition: all 0.3s ease;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-input-{{ ai_gen_id }},
  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-textarea-{{ ai_gen_id }},
  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-select-{{ ai_gen_id }} {
    background-color: {{ block.settings.how_it_works_input_background }};
    color: {{ block.settings.how_it_works_input_text }};
    border-color: {{ block.settings.how_it_works_input_border }};
  }

  .ai-custom-request-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-custom-request-radio-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-custom-request-radio-option-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-custom-request-radio-option-{{ ai_gen_id }} input[type="radio"] {
    margin: 0;
  }

  .ai-custom-request-radio-option-{{ ai_gen_id }} label {
    margin: 0;
    color: {{ block.settings.modal_text_color }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    transition: color 0.3s ease;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-radio-option-{{ ai_gen_id }} label {
    color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-step-buttons-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    margin-top: 30px;
    gap: 15px;
  }

  .ai-custom-request-btn-{{ ai_gen_id }} {
    padding: 12px 24px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-custom-request-btn-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-custom-request-btn-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-btn-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.how_it_works_modal_text }};
    color: {{ block.settings.how_it_works_modal_background }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-btn-primary-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-custom-request-btn-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.modal_text_color }};
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-custom-request-btn-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.input_border_color }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-btn-secondary-{{ ai_gen_id }} {
    color: {{ block.settings.how_it_works_modal_text }};
    border-color: {{ block.settings.how_it_works_input_border }};
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-btn-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.how_it_works_input_border }};
  }

  .ai-custom-request-progress-{{ ai_gen_id }} {
    width: 100%;
    height: 4px;
    background-color: {{ block.settings.input_border_color }};
    border-radius: 2px;
    margin-bottom: 30px;
    overflow: hidden;
  }

  .ai-custom-request-progress-bar-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.button_color }};
    transition: width 0.3s ease;
    border-radius: 2px;
  }

  .ai-custom-request-modal-content-{{ ai_gen_id }}.how-it-works-mode .ai-custom-request-progress-bar-{{ ai_gen_id }} {
    background-color: {{ block.settings.how_it_works_modal_text }};
  }

  .ai-custom-request-success-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.modal_text_color }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  .ai-custom-request-success-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 20px;
    background-color: #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
  }

  @media screen and (max-width: 768px) {
    .ai-custom-request-modal-content-{{ ai_gen_id }} {
      padding: 20px;
      margin: 10px;
    }

    .ai-custom-request-step-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<custom-request-form-{{ ai_gen_id }}
  class="ai-custom-request-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="ai-custom-request-button-{{ ai_gen_id }}"
    data-open-modal="consultation"
  >
    {{ block.settings.button_text }}
  </button>

  <div class="ai-custom-request-modal-{{ ai_gen_id }}" data-modal>
    <div class="ai-custom-request-modal-content-{{ ai_gen_id }}" data-modal-content>
      <button
        type="button"
        class="ai-custom-request-modal-close-{{ ai_gen_id }}"
        data-close-modal
      >
        ×
      </button>

      <div class="ai-custom-request-mode-toggle-{{ ai_gen_id }}">
        <button
          type="button"
          class="ai-custom-request-toggle-option-{{ ai_gen_id }}"
          data-toggle-mode="how-it-works"
        >
          {{ block.settings.how_it_works_toggle_text }}
        </button>
        <button
          type="button"
          class="ai-custom-request-toggle-option-{{ ai_gen_id }} active"
          data-toggle-mode="consultation"
        >
          {{ block.settings.consultation_toggle_text }}
        </button>
      </div>

      <div class="ai-custom-request-how-it-works-step-{{ ai_gen_id }}" data-how-it-works-content>
        <h2 class="ai-custom-request-step-title-{{ ai_gen_id }}">{{ block.settings.how_it_works_title }}</h2>
        <div class="ai-custom-request-how-it-works-content-{{ ai_gen_id }}">
          {{ block.settings.how_it_works_content }}
        </div>
      </div>

      <div class="ai-custom-request-consultation-content-{{ ai_gen_id }}" data-consultation-content>
        <div class="ai-custom-request-progress-{{ ai_gen_id }}">
          <div class="ai-custom-request-progress-bar-{{ ai_gen_id }}" data-progress-bar></div>
        </div>

        <form data-custom-request-form>
          <div class="ai-custom-request-step-{{ ai_gen_id }} active" data-step="1">
            <h2 class="ai-custom-request-step-title-{{ ai_gen_id }}">{{ block.settings.step1_title }}</h2>
            
            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="name-{{ ai_gen_id }}">{{ block.settings.name_label }}</label>
              <input
                type="text"
                id="name-{{ ai_gen_id }}"
                name="name"
                class="ai-custom-request-input-{{ ai_gen_id }}"
                required
              >
            </div>

            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">{{ block.settings.email_label }}</label>
              <input
                type="email"
                id="email-{{ ai_gen_id }}"
                name="email"
                class="ai-custom-request-input-{{ ai_gen_id }}"
                required
              >
            </div>

            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="phone-{{ ai_gen_id }}">{{ block.settings.phone_label }}</label>
              <input
                type="tel"
                id="phone-{{ ai_gen_id }}"
                name="phone"
                class="ai-custom-request-input-{{ ai_gen_id }}"
              >
            </div>

            <div class="ai-custom-request-step-buttons-{{ ai_gen_id }}">
              <div></div>
              <button type="button" class="ai-custom-request-btn-{{ ai_gen_id }} ai-custom-request-btn-primary-{{ ai_gen_id }}" data-next-step>
                {{ block.settings.next_button_text }}
              </button>
            </div>
          </div>

          <div class="ai-custom-request-step-{{ ai_gen_id }}" data-step="2">
            <h2 class="ai-custom-request-step-title-{{ ai_gen_id }}">{{ block.settings.step2_title }}</h2>
            
            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}">{{ block.settings.project_type_label }}</label>
              <div class="ai-custom-request-radio-group-{{ ai_gen_id }}">
                {% assign project_types = block.settings.project_types | split: ',' %}
                {% for type in project_types %}
                  {% assign trimmed_type = type | strip %}
                  {% if trimmed_type != blank %}
                    <div class="ai-custom-request-radio-option-{{ ai_gen_id }}">
                      <input
                        type="radio"
                        id="project-{{ forloop.index }}-{{ ai_gen_id }}"
                        name="project_type"
                        value="{{ trimmed_type }}"
                        {% if forloop.first %}required{% endif %}
                      >
                      <label for="project-{{ forloop.index }}-{{ ai_gen_id }}">{{ trimmed_type }}</label>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="budget-{{ ai_gen_id }}">{{ block.settings.budget_label }}</label>
              <select
                id="budget-{{ ai_gen_id }}"
                name="budget"
                class="ai-custom-request-select-{{ ai_gen_id }}"
                required
              >
                <option value="">{{ block.settings.budget_placeholder }}</option>
                {% assign budget_ranges = block.settings.budget_ranges | split: ',' %}
                {% for range in budget_ranges %}
                  {% assign trimmed_range = range | strip %}
                  {% if trimmed_range != blank %}
                    <option value="{{ trimmed_range }}">{{ trimmed_range }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>

            <div class="ai-custom-request-step-buttons-{{ ai_gen_id }}">
              <button type="button" class="ai-custom-request-btn-{{ ai_gen_id }} ai-custom-request-btn-secondary-{{ ai_gen_id }}" data-prev-step>
                {{ block.settings.back_button_text }}
              </button>
              <button type="button" class="ai-custom-request-btn-{{ ai_gen_id }} ai-custom-request-btn-primary-{{ ai_gen_id }}" data-next-step>
                {{ block.settings.next_button_text }}
              </button>
            </div>
          </div>

          <div class="ai-custom-request-step-{{ ai_gen_id }}" data-step="3">
            <h2 class="ai-custom-request-step-title-{{ ai_gen_id }}">{{ block.settings.step3_title }}</h2>
            
            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="timeline-{{ ai_gen_id }}">{{ block.settings.timeline_label }}</label>
              <select
                id="timeline-{{ ai_gen_id }}"
                name="timeline"
                class="ai-custom-request-select-{{ ai_gen_id }}"
                required
              >
                <option value="">{{ block.settings.timeline_placeholder }}</option>
                {% assign timelines = block.settings.timeline_options | split: ',' %}
                {% for timeline in timelines %}
                  {% assign trimmed_timeline = timeline | strip %}
                  {% if trimmed_timeline != blank %}
                    <option value="{{ trimmed_timeline }}">{{ trimmed_timeline }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>

            <div class="ai-custom-request-form-group-{{ ai_gen_id }}">
              <label class="ai-custom-request-label-{{ ai_gen_id }}" for="description-{{ ai_gen_id }}">{{ block.settings.description_label }}</label>
              <textarea
                id="description-{{ ai_gen_id }}"
                name="description"
                class="ai-custom-request-textarea-{{ ai_gen_id }}"
                placeholder="{{ block.settings.description_placeholder }}"
                required
              ></textarea>
            </div>

            <div class="ai-custom-request-step-buttons-{{ ai_gen_id }}">
              <button type="button" class="ai-custom-request-btn-{{ ai_gen_id }} ai-custom-request-btn-secondary-{{ ai_gen_id }}" data-prev-step>
                {{ block.settings.back_button_text }}
              </button>
              <button type="submit" class="ai-custom-request-btn-{{ ai_gen_id }} ai-custom-request-btn-primary-{{ ai_gen_id }}">
                {{ block.settings.submit_button_text }}
              </button>
            </div>
          </div>

          <div class="ai-custom-request-step-{{ ai_gen_id }}" data-step="success">
            <div class="ai-custom-request-success-{{ ai_gen_id }}">
              <div class="ai-custom-request-success-icon-{{ ai_gen_id }}">
                ✓
              </div>
              <h2 class="ai-custom-request-step-title-{{ ai_gen_id }}">{{ block.settings.success_title }}</h2>
              <p>{{ block.settings.success_message }}</p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</custom-request-form-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomRequestForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentStep = 1;
        this.totalSteps = 3;
        this.formData = {};
        this.currentMode = 'consultation';
      }

      connectedCallback() {
        this.modal = this.querySelector('[data-modal]');
        this.modalContent = this.querySelector('[data-modal-content]');
        this.form = this.querySelector('[data-custom-request-form]');
        this.progressBar = this.querySelector('[data-progress-bar]');
        this.steps = this.querySelectorAll('[data-step]');
        this.howItWorksContent = this.querySelector('[data-how-it-works-content]');
        this.consultationContent = this.querySelector('[data-consultation-content]');
        
        this.setupEventListeners();
        this.updateProgress();
        this.updateModeDisplay();
      }

      setupEventListeners() {
        const openButton = this.querySelector('[data-open-modal]');
        const closeButton = this.querySelector('[data-close-modal]');
        const nextButtons = this.querySelectorAll('[data-next-step]');
        const prevButtons = this.querySelectorAll('[data-prev-step]');
        const toggleButtons = this.querySelectorAll('[data-toggle-mode]');

        openButton.addEventListener('click', () => this.openModal('consultation'));

        closeButton.addEventListener('click', () => this.closeModal());
        
        nextButtons.forEach(button => {
          button.addEventListener('click', () => this.nextStep());
        });
        
        prevButtons.forEach(button => {
          button.addEventListener('click', () => this.prevStep());
        });

        toggleButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const mode = e.target.getAttribute('data-toggle-mode');
            this.switchMode(mode);
          });
        });

        this.form.addEventListener('submit', (e) => this.handleSubmit(e));

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal(mode = 'consultation') {
        this.switchMode(mode);
        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }

      switchMode(mode) {
        this.currentMode = mode;
        
        const toggleButtons = this.querySelectorAll('[data-toggle-mode]');
        toggleButtons.forEach(button => {
          button.classList.remove('active');
          if (button.getAttribute('data-toggle-mode') === mode) {
            button.classList.add('active');
          }
        });

        if (mode === 'how-it-works') {
          this.modalContent.classList.add('how-it-works-mode');
          this.howItWorksContent.style.display = 'block';
          this.consultationContent.style.display = 'none';
        } else {
          this.modalContent.classList.remove('how-it-works-mode');
          this.howItWorksContent.style.display = 'none';
          this.consultationContent.style.display = 'block';
        }

        this.updateModeDisplay();
      }

      updateModeDisplay() {
        if (this.currentMode === 'consultation') {
          this.showStep(this.currentStep);
          this.updateProgress();
        }
      }

      nextStep() {
        if (this.validateCurrentStep()) {
          this.saveCurrentStepData();
          this.currentStep++;
          this.showStep(this.currentStep);
          this.updateProgress();
        }
      }

      prevStep() {
        this.currentStep--;
        this.showStep(this.currentStep);
        this.updateProgress();
      }

      showStep(stepNumber) {
        this.steps.forEach(step => {
          step.classList.remove('active');
        });
        
        const targetStep = this.querySelector(`[data-step="${stepNumber}"]`);
        if (targetStep) {
          targetStep.classList.add('active');
        }
      }

      updateProgress() {
        const progress = (this.currentStep / this.totalSteps) * 100;
        this.progressBar.style.width = `${progress}%`;
      }

      validateCurrentStep() {
        const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
        const requiredFields = currentStepElement.querySelectorAll('[required]');
        
        for (let field of requiredFields) {
          if (!field.value.trim()) {
            field.focus();
            return false;
          }
          
          if (field.type === 'email' && !this.isValidEmail(field.value)) {
            field.focus();
            return false;
          }
        }
        
        return true;
      }

      isValidEmail(email) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return emailRegex.test(email);
      }

      saveCurrentStepData() {
        const currentStepElement = this.querySelector(`[data-step="${this.currentStep}"]`);
        const inputs = currentStepElement.querySelectorAll('input, select, textarea');
        
        inputs.forEach(input => {
          if (input.type === 'radio') {
            if (input.checked) {
              this.formData[input.name] = input.value;
            }
          } else {
            this.formData[input.name] = input.value;
          }
        });
      }

      async handleSubmit(e) {
        e.preventDefault();
        
        if (!this.validateCurrentStep()) {
          return;
        }
        
        this.saveCurrentStepData();
        
        try {
          const formData = new FormData();
          formData.append('contact[tags]', 'custom-piece-request');
          
          Object.entries(this.formData).forEach(([key, value]) => {
            formData.append(`contact[${key}]`, value);
          });

          const response = await fetch('/contact', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            this.showStep('success');
            
            if (window.BookX && typeof window.BookX.openBooking === 'function') {
              setTimeout(() => {
                window.BookX.openBooking();
              }, 2000);
            }
            
            setTimeout(() => {
              this.closeModal();
              this.resetForm();
              window.location.href = '/';
            }, 5000);
          } else {
            throw new Error('Form submission failed');
          }
        } catch (error) {
          console.error('Error submitting form:', error);
          alert('There was an error submitting your request. Please try again.');
        }
      }

      resetForm() {
        this.currentStep = 1;
        this.formData = {};
        this.form.reset();
        this.showStep(1);
        this.updateProgress();
        this.switchMode('consultation');
      }
    }

    customElements.define('custom-request-form-{{ ai_gen_id }}', CustomRequestForm{{ ai_gen_id }});
  })();
</script>

