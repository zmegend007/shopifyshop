{% doc %}
  @prompt
    Create a sophisticated gallery section for a high-end fashion brand using the Horizon theme. Build a responsive grid layout for 40 collection images with minimal spacing between tiles. Use 4 columns on desktop, 2 on tablet, 1 on mobile. Each image tile should have smooth hover animations revealing collection names in large serif font overlay text. Images should link to collection pages when clicked. Use clean white or beige background with minimal spacing for visual immersion. Focus on creating an art gallery or editorial wall aesthetic. No placeholder content - structure only for team to upload images and assign collection links. Prioritize elegance and let imagery dominate the layout., The format needs to allow the full image to fit and once all images are added I want you to place the images aesthetically based on size.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-gallery-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding }}px;
  }

  .ai-gallery-masonry-{{ ai_gen_id }} {
    column-count: 4;
    column-gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-gallery-tile-{{ ai_gen_id }} {
    position: relative;
    display: block;
    width: 100%;
    margin-bottom: {{ block.settings.grid_gap }}px;
    break-inside: avoid;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }

  .ai-gallery-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ai-gallery-tile-{{ ai_gen_id }}:hover .ai-gallery-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-gallery-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      rgba(0, 0, 0, 0.4) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-gallery-tile-{{ ai_gen_id }}:hover .ai-gallery-overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-gallery-title-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    font-weight: {{ settings.type_heading_font.weight }};
    font-size: {{ block.settings.overlay_font_size }}px;
    text-align: center;
    margin: 0;
    padding: 0 20px;
    line-height: 1.2;
    transform: translateY(10px);
    transition: transform 0.4s ease;
  }

  .ai-gallery-tile-{{ ai_gen_id }}:hover .ai-gallery-title-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .ai-gallery-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    padding-bottom: 100%;
    background-color: #f8f8f8;
    position: relative;
  }

  .ai-gallery-image-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 1024px) {
    .ai-gallery-masonry-{{ ai_gen_id }} {
      column-count: 2;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-masonry-{{ ai_gen_id }} {
      column-count: 1;
    }

    .ai-gallery-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.container_padding | times: 0.5 }}px;
    }

    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_font_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-gallery-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 0;
    }

    .ai-gallery-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.container_padding | times: 0.3 }}px;
    }
  }
{% endstyle %}

<section class="ai-gallery-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gallery-container-{{ ai_gen_id }}">
    <div class="ai-gallery-masonry-{{ ai_gen_id }}">
      {% for i in (1..40) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign collection_key = 'collection_' | append: i
          assign title_key = 'title_' | append: i
          
          assign image = block.settings[image_key]
          assign collection = block.settings[collection_key]
          assign custom_title = block.settings[title_key]
        %}

        {% if image or collection %}
          <a 
            href="{% if collection %}{{ collection.url }}{% else %}#{% endif %}"
            class="ai-gallery-tile-{{ ai_gen_id }}"
            {% if custom_title != blank or collection.title %}
              aria-label="View {{ custom_title | default: collection.title }}"
            {% endif %}
          >
            <div class="ai-gallery-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | default: custom_title | default: collection.title | escape }}"
                  class="ai-gallery-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% elsif collection and collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                  class="ai-gallery-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ collection.featured_image.width }}"
                  height="{{ collection.featured_image.height }}"
                >
              {% else %}
                <div class="ai-gallery-image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if custom_title != blank or collection.title %}
                <div class="ai-gallery-overlay-{{ ai_gen_id }}">
                  <h3 class="ai-gallery-title-{{ ai_gen_id }}">
                    {{ custom_title | default: collection.title }}
                  </h3>
                </div>
              {% endif %}
            </div>
          </a>
        {% else %}
          <div class="ai-gallery-tile-{{ ai_gen_id }}">
            <div class="ai-gallery-image-placeholder-{{ ai_gen_id }}">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

