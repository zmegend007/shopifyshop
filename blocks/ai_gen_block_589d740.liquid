{% doc %}
  @prompt
    Create a sophisticated gallery section for a high-end fashion brand using responsive grid layout for collection images. Build 4 columns on desktop, 2 on tablet, 1 on mobile with minimal spacing between tiles. Include smooth hover animations revealing collection names in large serif font overlay text. Images should link to collection pages when clicked. Use clean white or beige background with minimal spacing for visual immersion. Focus on creating an art gallery or editorial wall aesthetic with structure for team to upload images and assign collection links. Prioritize elegance and let imagery dominate the layout with full image fit and aesthetic placement based on image sizes.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-gallery-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-gallery-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: #f8f8f8;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    cursor: pointer;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.hover_scale }});
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform {{ block.settings.animation_duration }}ms ease;
    display: block;
  }

  .ai-gallery-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.overlay_color }};
    opacity: 0;
    transition: opacity {{ block.settings.animation_duration }}ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-gallery-title-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-family: {{ block.settings.title_font.family }}, serif;
    font-weight: {{ block.settings.title_font.weight }};
    text-align: center;
    margin: 0;
    line-height: 1.2;
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f8f8f8;
    position: relative;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gallery-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #999;
    text-align: center;
    padding: 8px 12px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    pointer-events: none;
  }

  @media screen and (max-width: 990px) {
    .ai-gallery-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
    
    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }
    
    .ai-gallery-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px;
    }
  }
{% endstyle %}

<section class="ai-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gallery-container-{{ ai_gen_id }}">
    <div class="ai-gallery-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign collection_key = 'collection_' | append: i
          assign title_key = 'title_' | append: i
          
          assign gallery_image = block.settings[image_key]
          assign gallery_collection = block.settings[collection_key]
          assign gallery_title = block.settings[title_key]
        %}
        
        {% if gallery_image != blank %}
          <a 
            href="{% if gallery_collection != blank %}{{ gallery_collection.url }}{% else %}#{% endif %}" 
            class="ai-gallery-item-{{ ai_gen_id }}"
            {% if gallery_collection == blank %}onclick="return false;"{% endif %}
          >
            <img
              src="{{ gallery_image | image_url: width: 800 }}"
              alt="{{ gallery_image.alt | escape }}"
              class="ai-gallery-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ gallery_image.width }}"
              height="{{ gallery_image.height }}"
            >
            <div class="ai-gallery-overlay-{{ ai_gen_id }}">
              <h3 class="ai-gallery-title-{{ ai_gen_id }}">
                {% if gallery_title != blank %}
                  {{ gallery_title }}
                {% elsif gallery_collection != blank %}
                  {{ gallery_collection.title }}
                {% else %}
                  Collection
                {% endif %}
              </h3>
            </div>
          </a>
        {% elsif forloop.index <= block.settings.visible_items %}
          <div class="ai-gallery-item-{{ ai_gen_id }}">
            <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
              <div class="ai-gallery-empty-state-{{ ai_gen_id }}">
                Add image {{ forloop.index }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

