    {
      "type": "range",
      "id": "selected_border_width",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "label": "Selected border width",
      "default": 2
    },
    {
      "type": "color",
      "id": "selected_border_color",
      "label": "Selected border color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "info_background",
      "label": "Info background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Checkbox"
    },
    {
      "type": "range",
      "id": "checkbox_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 28
    },
    {
      "type": "color",
      "id": "checkbox_background",
      "label": "Background",
      "default": "#ffffff"
