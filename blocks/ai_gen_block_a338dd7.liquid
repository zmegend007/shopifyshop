{% doc %}
  @prompt
    Make a block that says "As Seen In" and then a clickable image slot so I can link our editorial image where this garment is included in the look. This will act like a "recommended product" feature but serve to inspire the visitor rather than adding another product to the basket. Make it premium. , Make this two blocks within one block. Keep the first block like it is and next to it add a slot where I can link a specific instagram post of the garment. Use the same title and subtitle fields., Make it dynamic so that on desktop the layout is as wide as the product page and on mobile device: place the editorial block above the instagram block. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-as-seen-in-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: none;
  }

  .ai-as-seen-in-content-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .ai-as-seen-in-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-as-seen-in-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    font-weight: {{ settings.type_heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {% if block.settings.text_transform == 'uppercase' %}uppercase{% else %}none{% endif %};
  }

  .ai-as-seen-in-subtitle-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: 1.4;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    opacity: {{ block.settings.subtitle_opacity | divided_by: 100.0 }};
  }

  .ai-as-seen-in-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {% if block.settings.layout == 'equal' %}1fr 1fr{% elsif block.settings.layout == 'editorial_larger' %}1.2fr 0.8fr{% else %}0.8fr 1.2fr{% endif %};
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-as-seen-in-item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-as-seen-in-item-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.item_title_spacing }}px;
    text-align: {{ block.settings.item_text_alignment }};
  }

  .ai-as-seen-in-item-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_accent_font.family }}, {{ settings.type_accent_font.fallback_families }};
    font-weight: {{ settings.type_accent_font.weight }};
    font-size: {{ block.settings.item_title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.item_title_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-as-seen-in-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-as-seen-in-image-wrapper-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px) scale({{ block.settings.hover_scale | divided_by: 100.0 }});
    box-shadow: {{ block.settings.shadow_horizontal | times: 1.5 }}px {{ block.settings.shadow_vertical | times: 1.5 }}px {{ block.settings.shadow_blur | times: 2 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.3 | divided_by: 100.0 }});
  }

  .ai-as-seen-in-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ai-as-seen-in-image-wrapper-{{ ai_gen_id }}:hover .ai-as-seen-in-image-{{ ai_gen_id }} {
    filter: brightness({{ block.settings.hover_brightness }}%) contrast({{ block.settings.hover_contrast }}%);
  }

  .ai-as-seen-in-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      {{ block.settings.overlay_direction }}deg,
      {{ block.settings.overlay_color_start }} 0%,
      {{ block.settings.overlay_color_end }} 100%
    );
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-as-seen-in-image-wrapper-{{ ai_gen_id }}:hover .ai-as-seen-in-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-as-seen-in-overlay-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-family: {{ settings.type_accent_font.family }}, {{ settings.type_accent_font.fallback_families }};
    font-weight: {{ settings.type_accent_font.weight }};
    font-size: {{ block.settings.overlay_text_size }}px;
    text-align: center;
    padding: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.3;
  }

  .ai-as-seen-in-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.placeholder_height }}px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border: 2px dashed rgba(0, 0, 0, 0.1);
  }

  .ai-as-seen-in-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
    color: #6c757d;
  }

  .ai-as-seen-in-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    padding: 6px 12px;
    border-radius: 16px;
    font-size: 11px;
    color: #6c757d;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .ai-as-seen-in-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    right: {{ block.settings.badge_position_right }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-family: {{ settings.type_accent_font.family }}, {{ settings.type_accent_font.fallback_families }};
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 3;
    opacity: {{ block.settings.badge_opacity | divided_by: 100.0 }};
    transition: all 0.3s ease;
  }

  .ai-as-seen-in-image-wrapper-{{ ai_gen_id }}:hover .ai-as-seen-in-badge-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-as-seen-in-instagram-badge-{{ ai_gen_id }} {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .ai-as-seen-in-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-as-seen-in-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-as-seen-in-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-as-seen-in-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }

    .ai-as-seen-in-item-{{ ai_gen_id }}:nth-child(1) {
      order: {% if block.settings.mobile_order == 'editorial_first' %}1{% else %}2{% endif %};
    }

    .ai-as-seen-in-item-{{ ai_gen_id }}:nth-child(2) {
      order: {% if block.settings.mobile_order == 'editorial_first' %}2{% else %}1{% endif %};
    }

    .ai-as-seen-in-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size | times: 0.9 }}px;
    }

    .ai-as-seen-in-image-wrapper-{{ ai_gen_id }}:hover {
      transform: translateY(-{{ block.settings.hover_lift | times: 0.5 }}px) scale({{ block.settings.hover_scale | minus: 2 | divided_by: 100.0 }});
    }

    .ai-as-seen-in-overlay-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_text_size | times: 0.9 }}px;
      padding: 15px;
    }

    .ai-as-seen-in-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.placeholder_height | times: 0.8 }}px;
    }

    .ai-as-seen-in-item-header-{{ ai_gen_id }} {
      text-align: center;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-as-seen-in-{{ ai_gen_id }} {
      margin-left: calc(-1 * var(--page-width-margin, 2rem));
      margin-right: calc(-1 * var(--page-width-margin, 2rem));
      padding-left: calc({{ block.settings.padding_horizontal }}px + var(--page-width-margin, 2rem));
      padding-right: calc({{ block.settings.padding_horizontal }}px + var(--page-width-margin, 2rem));
    }
  }

  @media screen and (min-width: 990px) {
    .ai-as-seen-in-{{ ai_gen_id }} {
      margin-left: calc(-1 * var(--page-width-margin, 5rem));
      margin-right: calc(-1 * var(--page-width-margin, 5rem));
      padding-left: calc({{ block.settings.padding_horizontal }}px + var(--page-width-margin, 5rem));
      padding-right: calc({{ block.settings.padding_horizontal }}px + var(--page-width-margin, 5rem));
    }
  }

  @media screen and (min-width: 1200px) {
    .ai-as-seen-in-content-{{ ai_gen_id }} {
      max-width: {{ block.settings.desktop_max_width }}px;
      margin: 0 auto;
    }
  }
{% endstyle %}

<div class="ai-as-seen-in-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-in-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-as-seen-in-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-as-seen-in-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-as-seen-in-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-as-seen-in-grid-{{ ai_gen_id }}">
      <div class="ai-as-seen-in-item-{{ ai_gen_id }}">
        {% if block.settings.editorial_title != blank %}
          <div class="ai-as-seen-in-item-header-{{ ai_gen_id }}">
            <h3 class="ai-as-seen-in-item-title-{{ ai_gen_id }}">{{ block.settings.editorial_title }}</h3>
          </div>
        {% endif %}

        {% if block.settings.editorial_link != blank %}
          <a href="{{ block.settings.editorial_link }}" class="ai-as-seen-in-image-wrapper-{{ ai_gen_id }}" aria-label="View editorial feature">
        {% else %}
          <div class="ai-as-seen-in-image-wrapper-{{ ai_gen_id }}">
        {% endif %}

          {% if block.settings.editorial_image != blank %}
            <img
              src="{{ block.settings.editorial_image | image_url: width: 800 }}"
              alt="{{ block.settings.editorial_image.alt | default: block.settings.editorial_title | escape }}"
              class="ai-as-seen-in-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.editorial_image.width }}"
              height="{{ block.settings.editorial_image.height }}"
            >
            
            {% if block.settings.show_overlay %}
              <div class="ai-as-seen-in-overlay-{{ ai_gen_id }}">
                <div class="ai-as-seen-in-overlay-text-{{ ai_gen_id }}">
                  {{ block.settings.editorial_overlay_text }}
                </div>
              </div>
            {% endif %}

            {% if block.settings.show_editorial_badge and block.settings.editorial_badge_text != blank %}
              <div class="ai-as-seen-in-badge-{{ ai_gen_id }}">
                {{ block.settings.editorial_badge_text }}
              </div>
            {% endif %}
          {% else %}
            <div class="ai-as-seen-in-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-as-seen-in-empty-state-{{ ai_gen_id }}">
                Add editorial image
              </div>
            </div>
          {% endif %}

        {% if block.settings.editorial_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>

      <div class="ai-as-seen-in-item-{{ ai_gen_id }}">
        {% if block.settings.instagram_title != blank %}
          <div class="ai-as-seen-in-item-header-{{ ai_gen_id }}">
            <h3 class="ai-as-seen-in-item-title-{{ ai_gen_id }}">{{ block.settings.instagram_title }}</h3>
          </div>
        {% endif %}

        {% if block.settings.instagram_link != blank %}
          <a href="{{ block.settings.instagram_link }}" class="ai-as-seen-in-image-wrapper-{{ ai_gen_id }}" aria-label="View Instagram post" target="_blank" rel="noopener">
        {% else %}
          <div class="ai-as-seen-in-image-wrapper-{{ ai_gen_id }}">
        {% endif %}

          {% if block.settings.instagram_image != blank %}
            <img
              src="{{ block.settings.instagram_image | image_url: width: 800 }}"
              alt="{{ block.settings.instagram_image.alt | default: block.settings.instagram_title | escape }}"
              class="ai-as-seen-in-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.instagram_image.width }}"
              height="{{ block.settings.instagram_image.height }}"
            >
            
            {% if block.settings.show_overlay %}
              <div class="ai-as-seen-in-overlay-{{ ai_gen_id }}">
                <div class="ai-as-seen-in-overlay-text-{{ ai_gen_id }}">
                  {{ block.settings.instagram_overlay_text }}
                </div>
              </div>
            {% endif %}

            {% if block.settings.show_instagram_badge and block.settings.instagram_badge_text != blank %}
              <div class="ai-as-seen-in-badge-{{ ai_gen_id }} ai-as-seen-in-instagram-badge-{{ ai_gen_id }}">
                {{ block.settings.instagram_badge_text }}
              </div>
            {% endif %}
          {% else %}
            <div class="ai-as-seen-in-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-as-seen-in-empty-state-{{ ai_gen_id }}">
                Add Instagram image
              </div>
            </div>
          {% endif %}

        {% if block.settings.instagram_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

