<script>
  (function() {
    class StylistRentalRequest{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selectedProducts = new Set();
        this.drawerOpen = false;
      }

      connectedCallback() {
        this.webhookUrl = this.dataset.webhookUrl;
        this.cards = this.querySelectorAll('.ai-rental-request__card-{{ ai_gen_id }}');
        this.drawer = this.querySelector('[data-drawer]');
        this.drawerList = this.querySelector('[data-drawer-list]');
        this.drawerToggle = this.querySelector('[data-drawer-toggle]');
        this.countText = this.querySelector('[data-count-text]');
        this.expandIcon = this.querySelector('.ai-rental-request__expand-icon-{{ ai_gen_id }}');
        this.form = this.querySelector('[data-rental-form]');
        this.submitBtn = this.querySelector('[data-submit-btn]');
        this.submitText = this.querySelector('[data-submit-text]');
        this.successModal = this.querySelector('[data-success-modal]');
        this.modalClose = this.querySelector('[data-modal-close]');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach(card => {
          card.addEventListener('click', () => this.toggleProduct(card));
        });

        this.drawerToggle.addEventListener('click', () => this.toggleDrawer());

        this.form.addEventListener('submit', (e) => this.handleSubmit(e));

        this.modalClose.addEventListener('click', () => this.closeModal());

        this.successModal.addEventListener('click', (e) => {
          if (e.target === this.successModal) {
            this.closeModal();
          }
        });
      }

      toggleProduct(card) {
        const productId = card.dataset.productId;
        const productTitle = card.dataset.productTitle;
        const productImage = card.dataset.productImage;

        if (this.selectedProducts.has(productId)) {
          this.selectedProducts.delete(productId);
          card.classList.remove('ai-rental-request__card--selected-{{ ai_gen_id }}');
        } else {
          this.selectedProducts.add(productId);
          card.classList.add('ai-rental-request__card--selected-{{ ai_gen_id }}');
        }

        this.updateSelectionCount();
        this.updateDrawerList();
      }

      updateSelectionCount() {
        const count = this.selectedProducts.size;
        const text = count === 1 ? '1 garment selected' : count + ' garments selected';
        this.countText.textContent = text;
      }

      updateDrawerList() {
        this.drawerList.innerHTML = '';

        if (this.selectedProducts.size === 0) {
          this.drawerList.innerHTML = '<div style="text-align: center; padding: 20px; color: rgb(var(--color-foreground) / 0.6);">No garments selected</div>';
          return;
        }

        this.cards.forEach(card => {
          const productId = card.dataset.productId;
          if (this.selectedProducts.has(productId)) {
            const productTitle = card.dataset.productTitle;
            const productImage = card.dataset.productImage;

            const item = document.createElement('div');
            item.className = 'ai-rental-request__drawer-item-{{ ai_gen_id }}';
            item.innerHTML = `
              ${productImage ? 
                `<img src="${productImage}" alt="${productTitle}" class="ai-rental-request__drawer-thumb-{{ ai_gen_id }}">` :
                `<div class="ai-rental-request__drawer-thumb-placeholder-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>`
              }
              <div class="ai-rental-request__drawer-info-{{ ai_gen_id }}">${productTitle}</div>
              <button type="button" class="ai-rental-request__drawer-remove-{{ ai_gen_id }}" data-remove="${productId}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            `;

            const removeBtn = item.querySelector('[data-remove]');
            removeBtn.addEventListener('click', () => {
              this.selectedProducts.delete(productId);
              card.classList.remove('ai-rental-request__card--selected-{{ ai_gen_id }}');
              this.updateSelectionCount();
              this.updateDrawerList();
            });

            this.drawerList.appendChild(item);
          }
        });
      }

      toggleDrawer() {
        this.drawerOpen = !this.drawerOpen;
        if (this.drawerOpen) {
          this.drawer.classList.add('ai-rental-request__drawer--open-{{ ai_gen_id }}');
          this.expandIcon.classList.add('ai-rental-request__expand-icon--rotated-{{ ai_gen_id }}');
        } else {
          this.drawer.classList.remove('ai-rental-request__drawer--open-{{ ai_gen_id }}');
          this.expandIcon.classList.remove('ai-rental-request__expand-icon--rotated-{{ ai_gen_id }}');
        }
      }

      async handleSubmit(e) {
        e.preventDefault();

        this.clearErrors();

        if (this.selectedProducts.size === 0) {
          alert('Please select at least one garment');
          return;
        }

        if (!this.webhookUrl) {
          alert('Webhook URL not configured');
          return;
        }

        const formData = new FormData(this.form);
        const data = {
          selected_products: Array.from(this.selectedProducts),
          timestamp: new Date().toISOString()
        };

        for (let [key, value] of formData.entries()) {
          if (value) {
            data[key] = value;
          }
        }

        this.setLoading(true);

        try {
          const response = await fetch(this.webhookUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
          });

          if (!response.ok) {
            throw new Error('Submission failed');
          }

          this.showSuccessModal();
          this.resetForm();
        } catch (error) {
          console.error('Error:', error);
          alert('There was an error submitting your request. Please try again.');
        } finally {
          this.setLoading(false);
        }
      }

      setLoading(loading) {
        this.submitBtn.disabled = loading;
        if (loading) {
          this.submitText.innerHTML = '<span class="ai-rental-request__loading-{{ ai_gen_id }}"></span>';
        } else {
          this.submitText.textContent = '{{ block.settings.submit_button_text }}';
        }
      }

      clearErrors() {
        const errorElements = this.querySelectorAll('[data-error]');
        errorElements.forEach(el => el.textContent = '');
      }

      showSuccessModal() {
        this.successModal.classList.add('ai-rental-request__modal--open-{{ ai_gen_id }}');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.successModal.classList.remove('ai-rental-request__modal--open-{{ ai_gen_id }}');
        document.body.style.overflow = '';
      }

      resetForm() {
        this.form.reset();
        this.selectedProducts.clear();
        this.cards.forEach(card => {
          card.classList.remove('ai-rental-request__card--selected-{{ ai_gen_id }}');
        });
        this.updateSelectionCount();
        this.updateDrawerList();
        if (this.drawerOpen) {
          this.toggleDrawer();
        }
      }
    }

    customElements.define('stylist-rental-request-{{ ai_gen_id }}', StylistRentalRequest{{ ai_gen_id }});
  })();
</script>

